{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://halos.northharbor.dev/spec/schemas/halos-principles-v1.0.schema.json",
  "title": "HALOS Principles Spec",
  "description": "Machine-readable requirements for HALOS core alignment (v1.0)",
  "type": "object",
  "required": ["version", "requirements"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?(\\+[a-zA-Z0-9.-]+)?$",
      "description": "Semantic version of the principles spec"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^HALOS-CORE-\\d+$",
            "description": "Requirement identifier (e.g. HALOS-CORE-1)"
          },
          "title": {
            "type": "string",
            "description": "Short name for this requirement"
          },
          "description": {
            "type": "string",
            "description": "Normative description of this requirement"
          },
          "source": {
            "type": "string",
            "description": "Link to the source principle"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
