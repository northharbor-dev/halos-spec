{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://halos.northharbor.dev/spec/schema/manifest.schema.json",
  "title": "HALOS Manifest",
  "description": "Canonical discovery entry point for HALOS specification",
  "type": "object",
  "required": ["version", "specUrl", "core", "extensions", "changelogUrl"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?(\\+[a-zA-Z0-9.-]+)?$",
      "description": "Semantic version of the spec"
    },
    "specUrl": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical URL for this manifest"
    },
    "core": {
      "type": "object",
      "required": ["requirements"],
      "properties": {
        "requirements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of core requirements (e.g. HALOS-CORE-1)"
        }
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "required"],
        "properties": {
          "id": { "type": "string" },
          "required": { "type": "boolean", "const": false }
        }
      }
    },
    "changelogUrl": {
      "type": "string",
      "minLength": 1,
      "description": "URL to changelog.json"
    },
    "proposals": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Proposal IDs that produced this version"
    },
    "relatedSpecs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url", "relationship"],
        "properties": {
          "id": { "type": "string", "description": "Short identifier (e.g. ossa, agent-skills)" },
          "source": { "type": "string", "description": "Organization or project that maintains the spec (e.g. Anthropic, Google, OSSA)" },
          "url": { "type": "string", "description": "Canonical URL for the spec" },
          "relationship": { "type": "string", "description": "How HALOS relates: structural, capabilities, execution, communication, discovery, principles, accountability" }
        }
      },
      "description": "Related specs in the ecosystem; informational, not a formal dependency"
    }
  }
}
